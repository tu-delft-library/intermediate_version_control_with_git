git diff HEAD~2 HEAD~1 lines.txt 
git diff main b1 lines.txt 
git diff main b1~1 lines.txt 
git diff main~1 b1~1 lines.txt 
cat lines.txt 
nano lines.txt 
cat lines.txt 
git diff lines.txt 
git add lines.txt 
git commit -m "Corrected fifth line on main"
git log --oneline --graph
clear
git switch b2
git diff
cat lines.txt 
